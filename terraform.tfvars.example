aws_region               = "ap-southeast-1"
environment              = "dev"

internet_vpc_cidr        = "10.0.0.0/16"
workload_vpc_cidr        = "10.1.0.0/16"

availability_zones = [
    "ap-southeast-1a",
    "ap-southeast-1b"
]

# Internet VPC subnets
firewall_subnet_cidr     = "10.0.1.0/24"
gateway_subnet_cidrs     = ["10.0.2.0/24", "10.0.3.0/24"]
tgw_subnet_cidrs_internet = ["10.0.4.0/24", "10.0.5.0/24"]

# Workload VPC subnets
web_subnet_cidrs         = ["10.1.1.0/24", "10.1.2.0/24"]
app_subnet_cidr          = "10.1.3.0/24"
data_subnet_cidrs        = ["10.1.4.0/24", "10.1.5.0/24"]
tgw_subnet_cidr_workload = "10.1.6.0/24"

nlb_private_ips = ["10.1.1.10", "10.1.2.10"]

# Ecs
container_image = "k8s.gcr.io/e2e-test-images/echoserver:2.5"
container_port  = 8080
task_cpu        = 256
task_memory     = 512
desired_count   = 1

# Aurora
db_name         = "appdb"
master_username = "dbadmin"
master_password = "xxx"
